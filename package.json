{
  "name": "fan_selection",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "description": "Full-stack fan selection tool with Vue frontend and Node.js backend.",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "node server/index.js",
    "dev:client": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
